@{
    ViewData["Title"] = "Welcome";
}

<section class="hero-section rounded-4 overflow-hidden mb-5">
    <div class="row g-0 align-items-center">
        <div class="col-lg-7 p-5">
            <span class="badge text-bg-light mb-3">ColafHotel Reservation System</span>
            <h1 class="display-5 fw-bold mb-3">Stay in comfort, book with confidence.</h1>
            <p class="lead text-secondary mb-4">
                Browse stylish rooms, reserve your dates in minutes, and manage your bookings in one place.
            </p>
            <div class="d-flex flex-wrap gap-3">
                <a asp-controller="Room" asp-action="Index" class="btn btn-primary btn-lg px-4">Explore Rooms</a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg px-4">Create Account</a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg px-4">Login</a>
            </div>
        </div>

        <div class="col-lg-5 hero-accent p-5">
            <div class="stat-card">
                <p class="text-uppercase small fw-semibold mb-2">Guest Experience</p>
                <h2 class="mb-2">Modern rooms with seamless reservations</h2>
                <p class="mb-0 text-secondary">
                    Simple booking flow, profile management, and admin-ready operations.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1">Featured Rooms</h2>
            <p class="text-secondary mb-0">A quick look at our most popular spaces.</p>
        </div>
        <a asp-controller="Room" asp-action="Index" class="btn btn-outline-primary">
            View All Rooms
        </a>
    </div>

    <div class="row g-4">

        <!-- Room 1 -->
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm room-card">
                <div class="room-image-shell">
                    <div class="room-image-placeholder">Single</div>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h3 class="h5 mb-0">Garden Haven</h3>
                        <span class="badge rounded-pill text-bg-light">Single</span>
                    </div>
                    <p class="text-secondary">A cozy room with calm interior design and workspace.</p>
                    <p class="fw-semibold mb-3">₱3,200 / night</p>
                    <a asp-controller="Room" asp-action="Details" asp-route-id="1" class="btn btn-primary">
                        See Details
                    </a>
                </div>
            </div>
        </div>

        <!-- Room 2 -->
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm room-card">
                <div class="room-image-shell">
                    <div class="room-image-placeholder">Double</div>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h3 class="h5 mb-0">City Lights</h3>
                        <span class="badge rounded-pill text-bg-light">Double</span>
                    </div>
                    <p class="text-secondary">Spacious room with lounge seating and city views.</p>
                    <p class="fw-semibold mb-3">₱4,800 / night</p>
                    <a asp-controller="Room" asp-action="Details" asp-route-id="2" class="btn btn-primary">
                        See Details
                    </a>
                </div>
            </div>
        </div>

        <!-- Room 3 -->
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm room-card">
                <div class="room-image-shell">
                    <div class="room-image-placeholder">Suite</div>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h3 class="h5 mb-0">Skyline Suite</h3>
                        <span class="badge rounded-pill text-bg-light">Suite</span>
                    </div>
                    <p class="text-secondary">Premium suite with luxury space and skyline view.</p>
                    <p class="fw-semibold mb-3">₱8,500 / night</p>
                    <a asp-controller="Room" asp-action="Details" asp-route-id="3" class="btn btn-primary">
                        See Details
                    </a>
                </div>
            </div>
        </div>

    </div>
</section>